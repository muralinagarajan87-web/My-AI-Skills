# Test Case Management Tool - Backend Configuration

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=test_case_tool
DB_USER=postgres
DB_PASSWORD=change-this-strong-password

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-this-in-production

# Server
PORT=5000
NODE_ENV=production

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
